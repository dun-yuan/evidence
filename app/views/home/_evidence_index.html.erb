<!-- Beta Development Announcement Bar -->
<div class="announcement-bar" style="background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); color: white; padding: 12px 0; text-align: center; position: sticky; top: 0; z-index: 1000; box-shadow: 0 2px 8px rgba(0,0,0,0.1);">
  <div class="container">
    <div class="row align-items-center">
      <div class="col-12">
        <span style="font-weight: 600; font-size: 14px;">
          📢 Evidence is currently in beta development and not open for submissions. 
          <a href="https://neurolibre.org" style="color: #fff; text-decoration: underline; margin-left: 8px;">Visit NeuroLibre for active submissions</a>
        </span>
      </div>
    </div>
  </div>
</div>

<div class="container">
  <%# <div class="hero min-vh-100 align-items-top"> %>
  <div class="hero" style="min-height: 500px; align-items: center;">
    <div class="hero-nav col-lg-4">
      <%= javascript_include_tag 'evidence/interactive_logo' %>
      <div id="svg-container"></div>
    </div>

    <div class="hero-content offset-lg-1 col-lg-7">
      <div class="content-card">
        <div class="card-inner">
          <div class="card-front">
            <h1><%= Rails.application.settings['abbreviation'] %> is <%= setting(:tagline).html_safe %></h1>
            <p class="lead">Interactive, online-executable preprints that can import each other and evolve with new data.</p>
            <hr>
            <div class="hero-ctas">
              <%= link_to "⚡️ Quickstart with templates".html_safe, templates_path, class: "btn" %>
              <%= link_to "🌱 Submit a living preprint".html_safe, setting(:reviewers_signup_url), class: "btn" %>
            </div>
          </div>
          <div class="card-back">
            <div id="component-description"></div>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<div class="row justify-content-center" style="background-color:#e7eee8; margin-top: 20px; margin-bottom: 20px; padding: 10px;">
  <div class="col-lg-6">
    <div class="nav-links-row">
      <%= link_to papers_path, class: "nav-link" do %>
        <%= image_tag 'icon_papers.svg' %>
    <span>Explore Preprints</span>
  <% end %>
  <%= link_to "https://docs.neurolibre.org", class: "nav-link" do %>
    <%= image_tag 'icon_docs.svg' %>
    <span>Documentation</span>
  <% end %>
</div>
</div>
</div> 

<div class="container">
  <h4>Recently Published Living Preprints <span class="badge-count"><%= Paper.visible.count %></span></h4>
  <div class="paper-list" id="all-papers">
    <%= render partial: "papers/evidence_list", locals: { papers: @papers } %>
  </div>

  <div class="my-5 text-center">
    <%= link_to "View all papers".html_safe, published_papers_path, class: "btn", data: { text: "View all papers"} %>
  </div>
</div>
